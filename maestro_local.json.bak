[
    {
        "etiqueta": "grifo_goteando",
        "sinonimos": ["grifo de lavabo gotea", "grifo pierde agua", "grifo fugando"],
        "respuesta": [
            "Cierra el paso de agua del lavabo o cocina.",
            "Revisa si el goteo viene del cartucho interior.",
            "Si puedes, manda una foto por WhatsApp 📸 para confirmar el tipo de grifo.",
            "El cambio de cartucho suele costar menos que cambiar el grifo entero.",
            "Si es necesario, cambia el cartucho o llama a un técnico."
        ]
    },
    {
        "etiqueta": "ducha_pierde_agua",
        "sinonimos": ["ducha con fuga", "ducha mojada", "ducha pierde agua"],
        "respuesta": [
            "Localiza si la fuga viene de una junta, tubería o desagüe.",
            "Si puedes, manda una foto por WhatsApp 📸 para ver si es reparación o cambio.",
            "Si es en pared, toca alrededor para ver si está húmedo.",
            "Cierra el paso general si la fuga es fuerte."
        ]
    },
    {
        "etiqueta": "ducha_fria",
        "sinonimos": ["agua fría en ducha", "ducha sin caliente"],
        "respuesta": [
            "Revisa que la caldera esté encendida y funcionando.",
            "Verifica que la mezcla de agua caliente y fría esté correctamente configurada.",
            "Si el problema persiste, contacta con un técnico."
        ]
    },
    {
        "etiqueta": "caldera_no_enciende",
        "sinonimos": ["caldera apagada", "caldera no funciona"],
        "respuesta": [
            "Revisa si hay luz o gas disponible.",
            "Comprueba los fusibles y el interruptor de la caldera.",
            "Si no enciende, contacta con un técnico especializado."
        ]
    },
    {
        "etiqueta": "lavadora_no_enciende",
        "sinonimos": ["lavadora apagada", "lavadora no funciona"],
        "respuesta": [
            "Envía fotos del panel o de la avería por WhatsApp 📸.",
            "Te indicaré cómo solucionarlo o si hace falta la intervención de un técnico."
        ]
    },
    {
        "etiqueta": "cisterna_pierde",
        "sinonimos": ["cisterna con fuga", "cisterna pierde agua"],
        "respuesta": [
            "Levanta la tapa y revisa si flota bien el mecanismo.",
            "Muchas veces se arregla cambiando la boya.",
            "Envíame foto del interior para decirte si vale reparar o toca cambiar."
        ]
    },
